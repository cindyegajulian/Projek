        "# What is the transpose of this vektor?\n",
        "import numpy as np\n",
        "v = np.array([\n",
        "    [25],\n",
        "    [2],\n",
        "    [-3],\n",
        "    [-23]\n",
        "])\n",
        "v\n",
        "\n",
        "# transpose\n",
        "v_t = v.T\n",
        "v_t\n"
      ],
